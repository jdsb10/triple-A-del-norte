{
  "name": "triple-a-del-norte",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "packages/*",
    "apps/worker"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "dev:worker": "npm run dev --workspace=@triple-a/worker",
    "postinstall": "npm run generate --workspace=@triple-a/db",
    "db:generate": "npm run generate --workspace=@triple-a/db",
    "db:migrate": "npm run migrate --workspace=@triple-a/db",
    "db:seed": "npm run seed --workspace=@triple-a/db"
  },
  "dependencies": {
    "@triple-a/db": "*",
    "@triple-a/shared": "*",
    "next": "^14.2.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "clsx": "^2.1.1",
    "next-auth": "^4.24.10",
    "bcryptjs": "^2.4.3",
    "nextjs-toploader": "^3.7.15"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/bcryptjs": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "npm@10.9.8"
}
